# Alpha-Clawd Voice Bot Configuration
# Copy this file to .env and fill in secret values locally.

# Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_bot_token_here

# New Discord application/client ID and guild/server ID
DISCORD_CLIENT_ID=1500270320911650988
DISCORD_GUILD_ID=1500286124382486629

# Voice mode:
# fish         - Fish Audio TTS + Fish Audio ASR (default)
# fish-whisper - Fish Audio TTS + OpenAI Whisper STT
# elevenlabs   - ElevenLabs TTS + ElevenLabs STT
# free         - Edge TTS + OpenAI Whisper STT
# hybrid       - ElevenLabs TTS + OpenAI Whisper STT
# local        - Edge TTS + whisper.cpp STT
VOICE_MODE=fish

# Spoken response generator:
# direct  - low-latency structured JSON-schema generator for live podcast turns (default)
# gateway - legacy Gateway/OpenClaw agent generator
PODCAST_GENERATOR=direct
# The default Fish host path uses Anthropic Opus 4.7.
PODCAST_GENERATOR_BASE_URL=https://api.anthropic.com/v1
PODCAST_GENERATOR_MODEL=claude-opus-4-7
PODCAST_GENERATOR_TIMEOUT_MS=15000
PODCAST_GENERATOR_MAX_TOKENS=1500
PODCAST_GENERATOR_MAX_SPEECH_CHARS=420
# Request-size guard for Groq/OpenAI-compatible context windows.
PODCAST_GENERATOR_MAX_REQUEST_TOKENS=8000
PODCAST_GENERATOR_PROMPT_TOKEN_SAFETY_MARGIN=1024
PODCAST_GENERATOR_STAGED_BIG_BRAIN_MAX_CHARS=1800
PODCAST_GENERATOR_HISTORY_TURNS=8
# Defaults to strict json_schema. Models that reject json_schema are retried with
# json_object unless this fallback is disabled.
# PODCAST_GENERATOR_RESPONSE_FORMAT=json_schema
# PODCAST_GENERATOR_JSON_OBJECT_FALLBACK=true
# PODCAST_GENERATOR_REASONING_FORMAT=hidden
PODCAST_IDLE_DECISION_INTERVAL_MS=5000
# Free-first routing uses the free Groq key by default and falls back to paid
# only for live participant-triggered turns while the free key is cooling down.
PODCAST_GENERATOR_KEY_ROUTING=free-first-paid-fallback
# PODCAST_GENERATOR_API_KEY_GROQ_FREE=your_free_generator_key_here
# PODCAST_GENERATOR_API_KEY_GROQ_PAID=your_paid_generator_key_here
PODCAST_GENERATOR_PAID_SESSION_SOFT_CAP_USD=0.25
PODCAST_GENERATOR_PAID_DAILY_SOFT_CAP_USD=2

# Experimental full-duplex host. Select "Gemini Live (experimental)" from the
# /podcast-join engine option; the structured Claude + Fish path remains default.
# Fish ASR continues in parallel for the forensic episode transcript.
# GEMINI_API_KEY=your_google_ai_studio_api_key_here
PODCAST_GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
PODCAST_GEMINI_LIVE_VOICE=Aoede
# Hold explicit participant activity open across thoughtful pauses before Gemini may answer.
PODCAST_GEMINI_LIVE_ACTIVITY_RELEASE_MS=1500
# Legacy aliases still work:
# PODCAST_GENERATOR_API_KEY_ACTIVE=GROQ_PRIMARY
# PODCAST_GENERATOR_API_KEY_GROQ_PRIMARY=your_legacy_primary_key_here
# PODCAST_GENERATOR_API_KEY_GROQ_STANDBY=your_legacy_standby_key_here
# Optional. When direct mode is active, connect to Gateway only for visibility.
# PODCAST_GATEWAY_MIRROR=false
# Phase 2 bigBrain handoff. In direct mode, connect to Gateway so the small
# generator can hand factual/deeper requests to Open Claw.
PODCAST_BIG_BRAIN_ENABLED=true
PODCAST_BIG_BRAIN_THINKING=high
PODCAST_BIG_BRAIN_TIMEOUT_MS=180000

# Hold after host playback before buffered participant speech may trigger again.
CONVERSATION_BUFFER_COOLDOWN_PERIOD_MS=50

# Direct Claude Opus 3 handoff. The podcast generator can request bigHeart;
# the result is staged back into a later generator turn like bigBrain results.
PODCAST_BIG_HEART_ENABLED=true
PODCAST_BIG_HEART_MODEL=claude-3-opus-20240229
PODCAST_BIG_HEART_BASE_URL=https://api.anthropic.com/v1
PODCAST_BIG_HEART_TIMEOUT_MS=180000
PODCAST_BIG_HEART_MAX_TOKENS=1200
# PODCAST_BIG_HEART_API_KEY=your_anthropic_api_key_here

# Introspection frontier switch. When true, the internal-thought and
# discernment generators route to the frontier model below instead of the
# small-model defaults. The live spoken generator stays on its fast small
# model regardless. Trades latency/cost for forensic-quality reflection.
PODCAST_INTROSPECTION_FRONTIER_ENABLED=false
# Frontier overrides applied only when ENABLED above is true. Any value
# left unset falls back to the existing per-component env (e.g.,
# PODCAST_INTERNAL_THOUGHT_MODEL) and finally to the frontier defaults.
PODCAST_INTROSPECTION_FRONTIER_MODEL=claude-sonnet-4-5-20250929
# Prefer ANTHROPIC_API_KEY for local secrets. This component-specific key
# remains available if you want to isolate introspection billing/limits.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# PODCAST_INTROSPECTION_FRONTIER_API_KEY=
PODCAST_INTROSPECTION_FRONTIER_BASE_URL=https://api.anthropic.com/v1

# Awareness shelf: dormant plumbing for scene-scoped internal noticings that can
# be made available to the podcast generator across a few future host turns.
PODCAST_AWARENESS_SHELF_ENABLED=false
PODCAST_AWARENESS_SHELF_MAX_ITEMS=7
PODCAST_AWARENESS_SHELF_EXPIRE_AFTER_TURNS=4
PODCAST_VOICE_JOIN_ATTEMPTS=2
PODCAST_VOICE_JOIN_READY_TIMEOUT_MS=30000

# Show runner: private editorial/structural guidance injected into the
# podcast generator. It tracks covered angles, unused question lanes, and
# wrap-up timing. It can share the introspection frontier switch when enabled,
# or fall back to the normal generator routing when no show-runner key is set.
PODCAST_SHOW_RUNNER_ENABLED=false
PODCAST_SHOW_RUNNER_INTERVAL_TURNS=2
PODCAST_SHOW_RUNNER_MAX_MINUTES=0
PODCAST_SHOW_RUNNER_TRANSCRIPT_MAX_CHARS=12000
# PODCAST_SHOW_RUNNER_MODEL=
# PODCAST_SHOW_RUNNER_API_KEY=
# PODCAST_SHOW_RUNNER_BASE_URL=
# PODCAST_SHOW_RUNNER_BRIEF_PATH=
# PODCAST_SHOW_RUNNER_QUESTION_BANK_PATH=

# Fish Audio
FISH_AUDIO_API_KEY=your_fish_audio_key_here
FISH_AUDIO_VOICE_ID=e127c1a13d0b415da7d6c4c16861295f
FISH_AUDIO_MODEL=s2-pro
FISH_AUDIO_LATENCY=balanced
# Ogg Opus avoids a transcode before Discord playback.
FISH_AUDIO_FORMAT=opus
# @discordjs/voice sends Opus silence during synthesis gaps. At 20ms per
# frame, 1500 frames covers the 30-second Fish timeout without startup delay.
DISCORD_AUDIO_MAX_MISSED_FRAMES=1500
FISH_AUDIO_MP3_BITRATE=128
# Fish ASR upload format: false keeps 48kHz stereo, shadow compares both without
# affecting the turn, and true uploads only 16kHz mono. Default: false.
FISH_ASR_DOWNMIX=false
# Use Fish Audio WebSocket live TTS for generated podcast responses.
# Set false to fall back to the existing HTTP /v1/tts buffer path.
FISH_STREAMING=true
# If Fish returns 402 Insufficient Balance, use Edge TTS for spoken notices/responses.
VOICE_FISH_CREDIT_FALLBACK=true
# Optional ASR fallback after Fish 402: auto uses OpenAI Whisper when OPENAI_API_KEY is set.
# Other values: openai-whisper, local, none.
VOICE_FISH_ASR_FALLBACK=auto
# Minimum time between spoken ASR failure notices.
VOICE_ASR_ERROR_NOTICE_COOLDOWN_MS=60000
# Optional. Leave unset for auto; set false when forcing Fish S2 inline controls.
# FISH_AUDIO_NORMALIZE=false

# Optional OpenAI Whisper STT for VOICE_MODE=fish-whisper/free/hybrid
OPENAI_API_KEY=your_openai_key_here
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=en

# Optional ElevenLabs legacy modes
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=DusxpIechtn2D8hID1Jy

# Optional Edge TTS modes
EDGE_TTS_VOICE=en-US-MichelleNeural
EDGE_TTS_LANG=en-US

# Optional local whisper.cpp mode
WHISPER_CPP_PATH=/opt/whisper.cpp/build/bin/whisper-cli
WHISPER_CPP_MODEL=/opt/whisper.cpp/models/ggml-base.en.bin
WHISPER_CPP_THREADS=2
WHISPER_CPP_LANGUAGE=en

# Clawdbot Gateway
GATEWAY_URL=http://localhost:18789
GATEWAY_WS_URL=ws://localhost:18789/ws
GATEWAY_AUTH_TOKEN=dev-token
TARGET_SESSION_KEY=agent:main:main

# Shared network content root. Leave unset to use ../clawcast-network/content.
# CLAWCAST_CONTENT_ROOT=../clawcast-network/content
# PODCAST_ROOT=../clawcast-network/content

# Recording directory. Leave unset to use $PODCAST_ROOT/recordings.
# Relative paths are resolved from this discord-bot directory.
# RECORDING_DIR=../recordings

# Speaker IDs can also be passed to /podcast-join.
# JENSEN_DISCORD_ID=
# JADE_DISCORD_ID=
